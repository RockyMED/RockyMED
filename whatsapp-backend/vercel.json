{
  "version": 2,
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 300,
      "includeFiles": "src/certificates/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron/close-daily-operation",
      "schedule": "10 5 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
